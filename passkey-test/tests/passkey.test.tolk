import "@acton/testing/expect"

// ──────────────────────────────────────────────────────────────────────────
// TVM crypto opcodes used here (https://github.com/ton-blockchain/ton/blob/master/crypto/vm/tonops.cpp)
//
//   P256_CHKSIGNS:   d:Slice sig:Slice k:Slice -> Bool
//     Computes sha256(d) and ECDSA-P256-verifies `sig` against pubkey `k`.
//     Tolk pushes params left-to-right (rightmost ends up on top of the stack),
//     so the Tolk parameter order must be (d, sig, pubKey).
//   HASHEXT_SHA256:  s_1 ... s_n length:Int -> hash:Int
//     Concatenates the data bytes of n slices/builders and returns sha256 of
//     the concatenation. We use it to hash a clientDataJSON that has been
//     pre-split into 3 slices, without ever materialising the full JSON.
//
// Signature is raw r||s (64 bytes). Pubkey is the 33-byte SEC1 *compressed*
// encoding of the P-256 point.
// ──────────────────────────────────────────────────────────────────────────

// check-disable-next-line asm-function-missing-safety-comment
fun p256ChkSignS(d: slice, sig: slice, pubKey: slice): bool
    asm "P256_CHKSIGNS";

// check-disable-next-line asm-function-missing-safety-comment
fun sha256ThreeSlices(s1: slice, s2: slice, s3: slice): uint256
    asm "3 PUSHINT HASHEXT_SHA256";

// ──────────────────────────────────────────────────────────────────────────
// WebAuthn ES256 test vector. Generated by `node scripts/gen-test-vector.mjs`.
// Re-run that script to produce a fresh keypair and update the constants
// below. The math below is independent of which key was used; the test only
// requires that PUBKEY/SIG/CDJ_*/AUTH_DATA all come from the same run.
// ──────────────────────────────────────────────────────────────────────────

const PUBKEY_COMPRESSED   = "03d02fff0875cd8e10486a03434a72444085bb9aaece7a3bfa91ec44b536564092";
const SIGNATURE_RAW       = "faae8eb0f03ae82b75f5ec620de6b1611a4a4bd290b5c07fc31b458d7f13e6b0c2662ea51c00dd760c653c9007f50eeee3e3d69c6faa44016d7ebd7e63ef0dba";
const AUTH_DATA           = "49960de5880e8c687434170f6476605b8fe4aeb9a28632c7995cf3ba831d97630500000001";

// 3-piece split of clientDataJSON:
//   prefix         = `{"type":"webauthn.get","challenge":"`            (36 bytes)
//   challengeB64u  = base64url(32-byte challenge), no padding          (43 bytes)
//   suffix         = `","origin":"http://localhost:52261",...}`        (56 bytes)
const CDJ_PREFIX          = "7b2274797065223a22776562617574686e2e676574222c226368616c6c656e6765223a22";
const CDJ_CHALLENGE_B64U  = "536b744d545535505546465355315256566c645957564252556c4e5556565a5857466c6157317864586c38";
const CDJ_SUFFIX          = "222c226f726967696e223a22687474703a2f2f6c6f63616c686f73743a3532323631222c2263726f73734f726967696e223a66616c73657d";

// Precomputed sha256(clientDataJSON) for cross-checking the on-chain value.
const PRECOMPUTED_CDJ_HASH: uint256 = 0x0892ad0578c81da83b51e7cdfe5a20a1846fbf1fb8c8c548dc6afabe3656f60b;

// ──────────────────────────────────────────────────────────────────────────
// The old 5-cell WebAuthn layout this unit test exercises:
//
//   root cell:
//     data:   signature_raw (64 bytes = 512 bits)
//     ref[0]: cdj_prefix         — bytes of `{"type":"webauthn.get","challenge":"`
//     ref[1]: cdj_challenge_b64u — bytes of the 43-char base64url challenge
//     ref[2]: cdj_suffix         — bytes of `","origin":"…","crossOrigin":false}`
//     ref[3]: body cell          — the actual operation the wallet wants to run.
//                                  Its TVM cell hash, base64url-encoded, MUST equal
//                                  the contents of ref[1] — that's how the WebAuthn
//                                  challenge binds to a TON cell.
//
// Verification flow:
//   1. cdjHash = HASHEXT_SHA256(ref[0], ref[1], ref[2])  -> reproduces sha256(clientDataJSON)
//   2. signed  = authData || cdjHash                     -> what passkey actually signed
//   3. P256_CHKSIGNS(signed, sig, pubKey)                -> ECDSA verify
//   4. (separately) compare base64url(cell.hash(ref[3])) with the bytes of ref[1].
//      The current wallet external layout is more compact, but the crypto flow
//      is identical.
// ──────────────────────────────────────────────────────────────────────────

fun buildExternalRoot(): cell {
    val prefixCell    = beginCell().storeSlice(CDJ_PREFIX.hexToSlice()).endCell();
    val challengeCell = beginCell().storeSlice(CDJ_CHALLENGE_B64U.hexToSlice()).endCell();
    val suffixCell    = beginCell().storeSlice(CDJ_SUFFIX.hexToSlice()).endCell();
    // Placeholder body cell — in real life, this is the wallet's outgoing message.
    // The test does not care about its contents; we only check the layout works.
    val bodyCell      = beginCell().storeUint(0xdeadbeef, 32).endCell();

    return beginCell()
        .storeSlice(SIGNATURE_RAW.hexToSlice())
        .storeRef(prefixCell)
        .storeRef(challengeCell)
        .storeRef(suffixCell)
        .storeRef(bodyCell)
        .endCell();
}

get fun `test passkey: HASHEXT_SHA256 over 3 cdj slices == sha256(clientDataJSON)`() {
    val cdjHash = sha256ThreeSlices(
        CDJ_PREFIX.hexToSlice(),
        CDJ_CHALLENGE_B64U.hexToSlice(),
        CDJ_SUFFIX.hexToSlice(),
    );
    expect(cdjHash).toEqual(PRECOMPUTED_CDJ_HASH);
}

get fun `test passkey: end-to-end verify from 5-cell layout`() {
    val root = buildExternalRoot();

    // Parse exactly the way the contract will.
    var rs = root.beginParse();
    val sig = rs.loadBits(512);                 // signature_raw
    val cdjPrefix    = rs.loadRef().beginParse();
    val cdjChallenge = rs.loadRef().beginParse();
    val cdjSuffix    = rs.loadRef().beginParse();
    val body         = rs.loadRef();            // contract logic uses this; the test ignores it
    val _ = body;

    // 1. Reconstruct sha256(clientDataJSON) without ever materialising the full JSON.
    val cdjHash = sha256ThreeSlices(cdjPrefix, cdjChallenge, cdjSuffix);

    // 2. Build signedMessage = authData || sha256(clientDataJSON). 37 + 32 = 69 bytes,
    //    fits in one cell (552 bits, well under the 1023-bit limit).
    val signed = beginCell()
        .storeSlice(AUTH_DATA.hexToSlice())
        .storeUint(cdjHash, 256)
        .toSlice();

    // 3. ECDSA-P256-SHA256 verify.
    val ok = p256ChkSignS(signed, sig, PUBKEY_COMPRESSED.hexToSlice());
    expect(ok).toBeTrue();
}

get fun `test passkey: tampered cdj prefix breaks verification`() {
    // Flip the first byte of the JSON prefix (so the JSON isn't even valid {).
    val badPrefix = "ff2274797065223a22776562617574686e2e676574222c226368616c6c656e6765223a22".hexToSlice();
    val cdjHash = sha256ThreeSlices(
        badPrefix,
        CDJ_CHALLENGE_B64U.hexToSlice(),
        CDJ_SUFFIX.hexToSlice(),
    );
    val signed = beginCell()
        .storeSlice(AUTH_DATA.hexToSlice())
        .storeUint(cdjHash, 256)
        .toSlice();
    val ok = p256ChkSignS(signed, SIGNATURE_RAW.hexToSlice(), PUBKEY_COMPRESSED.hexToSlice());
    expect(ok).toBeFalse();
}

get fun `test passkey: tampered challenge bytes break verification`() {
    // Same prefix and suffix, but the challenge value is a different valid b64url string.
    // (last char of the b64u changed from '8' to '9'.)
    val badChallenge = "536b744d545535505546465355315256566c645957564252556c4e5556565a5857466c6157317864586c39".hexToSlice();
    val cdjHash = sha256ThreeSlices(
        CDJ_PREFIX.hexToSlice(),
        badChallenge,
        CDJ_SUFFIX.hexToSlice(),
    );
    val signed = beginCell()
        .storeSlice(AUTH_DATA.hexToSlice())
        .storeUint(cdjHash, 256)
        .toSlice();
    val ok = p256ChkSignS(signed, SIGNATURE_RAW.hexToSlice(), PUBKEY_COMPRESSED.hexToSlice());
    expect(ok).toBeFalse();
}

get fun `test passkey: tampered authData breaks verification`() {
    val cdjHash = sha256ThreeSlices(
        CDJ_PREFIX.hexToSlice(),
        CDJ_CHALLENGE_B64U.hexToSlice(),
        CDJ_SUFFIX.hexToSlice(),
    );
    // Flip rpIdHash[0].
    val badAuthData = "ff960de5880e8c687434170f6476605b8fe4aeb9a28632c7995cf3ba831d97630500000001".hexToSlice();
    val signed = beginCell()
        .storeSlice(badAuthData)
        .storeUint(cdjHash, 256)
        .toSlice();
    val ok = p256ChkSignS(signed, SIGNATURE_RAW.hexToSlice(), PUBKEY_COMPRESSED.hexToSlice());
    expect(ok).toBeFalse();
}
