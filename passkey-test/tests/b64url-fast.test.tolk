// ─── Gas measurements ─────────────────────────────────────────────────────

get fun `test fast gas: print all variants`() {
    val hash = loadHash32();
    val challenge = EXPECTED_B64U_HEX.hexToSlice();

    val a0 = getGasConsumedAtTheMoment();
    val r2 = verifyB64uChallenge_v2(hash, challenge);
    val a1 = getGasConsumedAtTheMoment();

    val b0 = getGasConsumedAtTheMoment();
    val r3 = verifyB64uChallenge_v3(hash, challenge);
    val b1 = getGasConsumedAtTheMoment();

    val c0 = getGasConsumedAtTheMoment();
    val r4 = verifyB64uChallenge_v4(hash, challenge);
    val c1 = getGasConsumedAtTheMoment();

    val d0 = getGasConsumedAtTheMoment();
    val r5 = verifyB64uChallenge_v5(hash, challenge);
    val d1 = getGasConsumedAtTheMoment();

    val e0 = getGasConsumedAtTheMoment();
    val r6 = verifyB64uChallenge_v6(hash, challenge);
    val e1 = getGasConsumedAtTheMoment();

    val f0 = getGasConsumedAtTheMoment();
    val r7 = verifyB64uChallenge_v7(hash, challenge);
    val f1 = getGasConsumedAtTheMoment();

    val g0 = getGasConsumedAtTheMoment();
    val r8 = verifyB64uChallenge_v8(hash, challenge);
    val g1 = getGasConsumedAtTheMoment();

    val h0 = getGasConsumedAtTheMoment();
    val r9 = verifyB64uChallenge_v9(hash, challenge);
    val h1 = getGasConsumedAtTheMoment();

    val i0 = getGasConsumedAtTheMoment();
    val r10 = verifyB64uChallenge_v10(hash, challenge);
    val i1 = getGasConsumedAtTheMoment();

    val hash128: int = 0x4a4b4c4d4e4f50515253545556575859;
    val challenge128 = "536b744d545535505546465355315256566c64595751".hexToSlice();
    val j0 = getGasConsumedAtTheMoment();
    val r11 = verifyB64uChallenge_v11(hash128, challenge128);
    val j1 = getGasConsumedAtTheMoment();

    val hash96: int = 0x4a4b4c4d4e4f505152535455;
    val challenge96 = "536b744d545535505546465355315256".hexToSlice();
    val k0 = getGasConsumedAtTheMoment();
    val r12 = verifyB64uChallenge_v12(hash96, challenge96);
    val k1 = getGasConsumedAtTheMoment();

    val l0 = getGasConsumedAtTheMoment();
    val r13 = verifyB64uChallenge_v13(hash96, challenge96);
    val l1 = getGasConsumedAtTheMoment();

    expect(r2).toBeTrue();
    expect(r3).toBeTrue();
    expect(r4).toBeTrue();
    expect(r5).toBeTrue();
    expect(r6).toBeTrue();
    expect(r7).toBeTrue();
    expect(r8).toBeTrue();
    expect(r9).toBeTrue();
    expect(r10).toBeTrue();
    expect(r11).toBeTrue();
    expect(r12).toBeTrue();
    expect(r13).toBeTrue();
    println("V2 (arith char + repeat + SDEQ)        : ", a1 - a0 - 26, " gas");
    println("V3 (compare-as-you-go, repeat, MUL)    : ", b1 - b0 - 26, " gas");
    println("V4 (compare-as-you-go, accumulator)    : ", c1 - c0 - 26, " gas");
    println("V5 (compare-as-you-go, shift-drain)    : ", d1 - d0 - 26, " gas");
    println("V6 (slice-lookup + repeat + cmp-as-go) : ", e1 - e0 - 26, " gas");
    println("V7 (fully unrolled, const shifts)      : ", f1 - f0 - 26, " gas");
    println("V8 (hoisted alphabet, repeat)          : ", g1 - g0 - 26, " gas");
    println("V9 (24-bit chunks, 4 chars/iter)       : ", h1 - h0 - 26, " gas");
    println("V10 (48-bit chunks, 8 chars/iter)      : ", i1 - i0 - 26, " gas");
    println("V11 (128-bit truncated hash, 22 chars) : ", j1 - j0 - 26, " gas");
    println("V12 ( 96-bit truncated hash, 16 chars) : ", k1 - k0 - 26, " gas");
    println("V13 (V12 unrolled, 2 chunks)           : ", l1 - l0 - 26, " gas");
}

// ─── End-to-end pre-ACCEPT cost ──────────────────────────────────────────

get fun `test fast gas: end-to-end (HASHEXT + V13 b64u + P256_CHKSIGNS)`() {
    val bodyHash96 = FAKE_BODY_HASH_96;
    val challenge = CDJ_CHALLENGE_43.hexToSlice();
    val prefix = CDJ_PREFIX.hexToSlice();
    val suffix = CDJ_SUFFIX.hexToSlice();
    val authData = AUTH_DATA.hexToSlice();
    val sig = SIGNATURE_RAW.hexToSlice();
    val pubKey = PUBKEY_COMPRESSED.hexToSlice();

    val start = getGasConsumedAtTheMoment();

    // 1. Body↔challenge binding (V13: 16-char b64u of a 96-bit body-hash prefix,
    //    fully unrolled; ~5100 gas).
    val boundOk = verifyB64uChallenge_v13(bodyHash96, challenge);

    // 2. Reconstruct sha256(clientDataJSON) over prefix‖challenge‖suffix.
    val cdjHash = sha256ThreeSlices(prefix, challenge, suffix);

    // 3. Build signedMessage = authData ‖ cdjHash and ECDSA-P256 verify.
    val signed = beginCell()
        .storeSlice(authData)
        .storeUint(cdjHash, 256)
        .endCell()
        .beginParse();
    val sigOk = p256ChkSignS(signed, sig, pubKey);

    val end = getGasConsumedAtTheMoment();

    expect(boundOk).toBeTrue();
    expect(sigOk).toBeTrue();
    println("end-to-end pre-ACCEPT verification gas : ", end - start - 26);
    println("  (target: <= 10000 gas)");
}
