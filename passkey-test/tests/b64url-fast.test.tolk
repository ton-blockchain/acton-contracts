import "@acton/testing/expect"
import "@acton/testing/assert"
import "@acton/io"
import "@stdlib/gas-payments"

// ──────────────────────────────────────────────────────────────────────────
// Goal: fit the entire passkey verification (HASHEXT_SHA256 + b64url check
// + P256_CHKSIGNS) under TON's 10000-gas external-message budget.
//
// Costs we cannot move:
//   HASHEXT_SHA256 over ~135 bytes  ≈    34 base + 4×135/33  ≈   50 gas
//   P256_CHKSIGNS                    =  3526 gas (fixed)
//   leaves ≈ 6400 gas for the b64url binding check.
//
// V1 (the baseline in b64url.test.tolk) eats ~22000 gas — way over budget.
// Below we benchmark progressively tighter encoders/comparators.
// ──────────────────────────────────────────────────────────────────────────

// ─── Branchless arithmetic char map (replaces 64-byte alphabet slice) ────
// In TVM, a `>` comparison returns -1 (true) or 0 (false). The expression
// below evaluates to:
//   v in 0..25  -> v + 65          ('A'..'Z')
//   v in 26..51 -> v + 65 + 6      ('a'..'z'), since (v>25)=-1 → -(-1)*6 = +6
//   v in 52..61 -> v + 65 + 6 - 75 ('0'..'9')
//   v == 62     -> v + 65 + 6 - 75 - 13 = 45 ('-')
//   v == 63     -> v + 65 + 6 - 75 - 13 + 49 = 95 ('_')
@inline
fun b64urlCharArith(v: int): int {
    return v + 65
        - ((v > 25) as int) * 6
        + ((v > 51) as int) * 75
        + ((v > 61) as int) * 13
        - ((v > 62) as int) * 49;
}

// ─── V2: arithmetic char + repeat() loop + bitsEqual (SDEQ) compare ──────

fun b64urlEncode32_v2(hash: uint256): slice {
    var b: builder = beginCell();
    var i: int = 0;
    repeat (42) {
        val v = (hash >> (250 - i * 6)) & 0x3F;
        b = b.storeUint(b64urlCharArith(v), 8);
        i += 1;
    }
    val last = (hash & 0xF) << 2;
    b = b.storeUint(b64urlCharArith(last), 8);
    return b.endCell().beginParse();
}

fun verifyB64uChallenge_v2(hash: uint256, challenge: slice): bool {
    return b64urlEncode32_v2(hash).bitsEqual(challenge);
}

// ─── V3: compare-as-you-go, no builder, no output slice ──────────────────
// Build the expected ASCII char from hash and compare it against each byte
// loaded from the challenge slice. Saves the cost of building/storing 43
// output bytes and the final SDEQ.
fun verifyB64uChallenge_v3(hash: uint256, challenge: slice): bool {
    var s: slice = challenge;
    var i: int = 0;
    repeat (42) {
        val v = (hash >> (250 - i * 6)) & 0x3F;
        if (b64urlCharArith(v) != s.loadUint(8)) {
            return false;
        }
        i += 1;
    }
    val last = (hash & 0xF) << 2;
    return b64urlCharArith(last) == s.loadUint(8);
}

// ─── V4: precompute the multiplier `i * 6` via a single accumulator ──────
// Removes the per-iteration MUL.
fun verifyB64uChallenge_v4(hash: uint256, challenge: slice): bool {
    var s: slice = challenge;
    var shift: int = 250;
    repeat (42) {
        val v = (hash >> shift) & 0x3F;
        if (b64urlCharArith(v) != s.loadUint(8)) {
            return false;
        }
        shift -= 6;
    }
    val last = (hash & 0xF) << 2;
    return b64urlCharArith(last) == s.loadUint(8);
}

// ─── V6: keep the slice-lookup alphabet, drop everything else ────────────
// Surprise from benchmarking: arithmetic char-mapping (V2..V5) is MORE
// expensive than skipBits+preloadUint, because each `(v > X) as int * k`
// expands to ~5 TVM ops, while skipBits+preloadUint is exactly 2.
// So the right move is to keep the lookup and trim everything else:
//   * no function call per char (skipBits/preloadUint inlined)
//   * no builder, no bitsHash, no SDEQ — compare each char as we read it
//   * `repeat(42)` (REPEAT op) instead of `while` (avoids per-iter compare)
//   * pre-decrement shift instead of recomputing `250 - i*6`

const B64URL_ALPHABET: slice =
    "4142434445464748494a4b4c4d4e4f505152535455565758595a6162636465666768696a6b6c6d6e6f707172737475767778797a303132333435363738392d5f"
        .hexToSlice();

fun verifyB64uChallenge_v6(hash: uint256, challenge: slice): bool {
    var input: slice = challenge;
    var shift: int = 250;
    repeat (42) {
        val v = (hash >> shift) & 0x3F;
        var alpha = B64URL_ALPHABET;
        alpha.skipBits(v * 8);
        if (alpha.preloadUint(8) != input.loadUint(8)) {
            return false;
        }
        shift -= 6;
    }
    val last = (hash & 0xF) << 2;
    var alpha2 = B64URL_ALPHABET;
    alpha2.skipBits(last * 8);
    return alpha2.preloadUint(8) == input.loadUint(8);
}

// ─── V7: fully unrolled, constant shifts (no `>>` on a variable) ─────────
// Hypothesis: TVM has cheaper opcodes for constant-arg right-shift vs the
// generic variable-shift. Hand-unrolling 43 iterations also kills repeat()
// counter overhead.
//
// We still use the slice-lookup alphabet (which V6 showed is the cheapest
// char map). The body is autogenerated by `passkey-test/scripts/gen-v7.mjs`
// — keep them in sync.

@inline
fun lookupAlpha(v: int): int {
    var a = B64URL_ALPHABET;
    a.skipBits(v * 8);
    return a.preloadUint(8);
}

fun verifyB64uChallenge_v7(hash: uint256, challenge: slice): bool {
    var s: slice = challenge;
    if (lookupAlpha((hash >> 250) & 0x3F) != s.loadUint(8)) { return false; }
    if (lookupAlpha((hash >> 244) & 0x3F) != s.loadUint(8)) { return false; }
    if (lookupAlpha((hash >> 238) & 0x3F) != s.loadUint(8)) { return false; }
    if (lookupAlpha((hash >> 232) & 0x3F) != s.loadUint(8)) { return false; }
    if (lookupAlpha((hash >> 226) & 0x3F) != s.loadUint(8)) { return false; }
    if (lookupAlpha((hash >> 220) & 0x3F) != s.loadUint(8)) { return false; }
    if (lookupAlpha((hash >> 214) & 0x3F) != s.loadUint(8)) { return false; }
    if (lookupAlpha((hash >> 208) & 0x3F) != s.loadUint(8)) { return false; }
    if (lookupAlpha((hash >> 202) & 0x3F) != s.loadUint(8)) { return false; }
    if (lookupAlpha((hash >> 196) & 0x3F) != s.loadUint(8)) { return false; }
    if (lookupAlpha((hash >> 190) & 0x3F) != s.loadUint(8)) { return false; }
    if (lookupAlpha((hash >> 184) & 0x3F) != s.loadUint(8)) { return false; }
    if (lookupAlpha((hash >> 178) & 0x3F) != s.loadUint(8)) { return false; }
    if (lookupAlpha((hash >> 172) & 0x3F) != s.loadUint(8)) { return false; }
    if (lookupAlpha((hash >> 166) & 0x3F) != s.loadUint(8)) { return false; }
    if (lookupAlpha((hash >> 160) & 0x3F) != s.loadUint(8)) { return false; }
    if (lookupAlpha((hash >> 154) & 0x3F) != s.loadUint(8)) { return false; }
    if (lookupAlpha((hash >> 148) & 0x3F) != s.loadUint(8)) { return false; }
    if (lookupAlpha((hash >> 142) & 0x3F) != s.loadUint(8)) { return false; }
    if (lookupAlpha((hash >> 136) & 0x3F) != s.loadUint(8)) { return false; }
    if (lookupAlpha((hash >> 130) & 0x3F) != s.loadUint(8)) { return false; }
    if (lookupAlpha((hash >> 124) & 0x3F) != s.loadUint(8)) { return false; }
    if (lookupAlpha((hash >> 118) & 0x3F) != s.loadUint(8)) { return false; }
    if (lookupAlpha((hash >> 112) & 0x3F) != s.loadUint(8)) { return false; }
    if (lookupAlpha((hash >> 106) & 0x3F) != s.loadUint(8)) { return false; }
    if (lookupAlpha((hash >> 100) & 0x3F) != s.loadUint(8)) { return false; }
    if (lookupAlpha((hash >>  94) & 0x3F) != s.loadUint(8)) { return false; }
    if (lookupAlpha((hash >>  88) & 0x3F) != s.loadUint(8)) { return false; }
    if (lookupAlpha((hash >>  82) & 0x3F) != s.loadUint(8)) { return false; }
    if (lookupAlpha((hash >>  76) & 0x3F) != s.loadUint(8)) { return false; }
    if (lookupAlpha((hash >>  70) & 0x3F) != s.loadUint(8)) { return false; }
    if (lookupAlpha((hash >>  64) & 0x3F) != s.loadUint(8)) { return false; }
    if (lookupAlpha((hash >>  58) & 0x3F) != s.loadUint(8)) { return false; }
    if (lookupAlpha((hash >>  52) & 0x3F) != s.loadUint(8)) { return false; }
    if (lookupAlpha((hash >>  46) & 0x3F) != s.loadUint(8)) { return false; }
    if (lookupAlpha((hash >>  40) & 0x3F) != s.loadUint(8)) { return false; }
    if (lookupAlpha((hash >>  34) & 0x3F) != s.loadUint(8)) { return false; }
    if (lookupAlpha((hash >>  28) & 0x3F) != s.loadUint(8)) { return false; }
    if (lookupAlpha((hash >>  22) & 0x3F) != s.loadUint(8)) { return false; }
    if (lookupAlpha((hash >>  16) & 0x3F) != s.loadUint(8)) { return false; }
    if (lookupAlpha((hash >>  10) & 0x3F) != s.loadUint(8)) { return false; }
    if (lookupAlpha((hash >>   4) & 0x3F) != s.loadUint(8)) { return false; }
    return lookupAlpha((hash & 0xF) << 2) == s.loadUint(8);
}

// ─── V8: hoist B64URL_ALPHABET out of the loop (avoid 43× PUSHSLICE) ─────
// PUSHSLICE of a 64-byte constant costs ≈22 + 64 = 86 gas. Doing that once
// per iteration burns ≈3700 gas across 43 iterations. Hoisting it to a
// local lets the compiler emit PUSH from stack instead.
fun verifyB64uChallenge_v8(hash: uint256, challenge: slice): bool {
    val alpha: slice = B64URL_ALPHABET;
    var input: slice = challenge;
    var shift: int = 250;
    repeat (42) {
        val v = (hash >> shift) & 0x3F;
        var a = alpha;
        a.skipBits(v * 8);
        if (a.preloadUint(8) != input.loadUint(8)) {
            return false;
        }
        shift -= 6;
    }
    val last = (hash & 0xF) << 2;
    var a = alpha;
    a.skipBits(last * 8);
    return a.preloadUint(8) == input.loadUint(8);
}

// ─── V9: process 24-bit chunks → 4 chars per iter, single NEQ ───────────
// 24 = LCM(6, 8): every 24 bits of hash maps to exactly 4 b64url chars and
// 4 ASCII bytes. Packing the 4 expected chars into a 32-bit int lets us do
// ONE input read (LDU 32) and ONE NEQ per 4 chars instead of four.
//
// 32 bytes = 10 full 24-bit chunks (= 40 chars) + 16 trailing bits (= 3 chars).
fun verifyB64uChallenge_v9(hash: uint256, challenge: slice): bool {
    val alpha: slice = B64URL_ALPHABET;
    var input: slice = challenge;
    var shift: int = 232;
    repeat (10) {
        val chunk = (hash >> shift) & 0xFFFFFF;
        val v0 = (chunk >> 18) & 0x3F;
        val v1 = (chunk >> 12) & 0x3F;
        val v2 = (chunk >> 6) & 0x3F;
        val v3 = chunk & 0x3F;
        var a0 = alpha; a0.skipBits(v0 * 8);
        var a1 = alpha; a1.skipBits(v1 * 8);
        var a2 = alpha; a2.skipBits(v2 * 8);
        var a3 = alpha; a3.skipBits(v3 * 8);
        val expected =
              (a0.preloadUint(8) << 24)
            | (a1.preloadUint(8) << 16)
            | (a2.preloadUint(8) << 8)
            |  a3.preloadUint(8);
        if (input.loadUint(32) != expected) { return false; }
        shift -= 24;
    }
    // Trailing 16 bits → 3 chars (last char encodes only 4 useful bits).
    val last16 = hash & 0xFFFF;
    val v0 = (last16 >> 10) & 0x3F;
    val v1 = (last16 >> 4) & 0x3F;
    val v2 = (last16 & 0xF) << 2;
    var a0 = alpha; a0.skipBits(v0 * 8);
    var a1 = alpha; a1.skipBits(v1 * 8);
    var a2 = alpha; a2.skipBits(v2 * 8);
    val expected =
          (a0.preloadUint(8) << 16)
        | (a1.preloadUint(8) << 8)
        |  a2.preloadUint(8);
    return input.loadUint(24) == expected;
}

// ─── V10: process 48-bit chunks → 8 chars per iter ──────────────────────
// 48 = LCM(6, 8) × 2. Each iteration consumes 6 hash bytes and verifies 8
// challenge bytes via a single LDU 64 + NEQ.
//   32 bytes = 5 full 6-byte chunks (40 chars) + 2 trailing bytes (3 chars).
fun verifyB64uChallenge_v10(hash: uint256, challenge: slice): bool {
    val alpha: slice = B64URL_ALPHABET;
    var input: slice = challenge;
    var shift: int = 208;   // 256 - 48
    repeat (5) {
        val chunk = (hash >> shift) & 0xFFFFFFFFFFFF;  // 48 bits
        val v0 = (chunk >> 42) & 0x3F;
        val v1 = (chunk >> 36) & 0x3F;
        val v2 = (chunk >> 30) & 0x3F;
        val v3 = (chunk >> 24) & 0x3F;
        val v4 = (chunk >> 18) & 0x3F;
        val v5 = (chunk >> 12) & 0x3F;
        val v6 = (chunk >>  6) & 0x3F;
        val v7 =  chunk        & 0x3F;
        var a0 = alpha; a0.skipBits(v0 * 8);
        var a1 = alpha; a1.skipBits(v1 * 8);
        var a2 = alpha; a2.skipBits(v2 * 8);
        var a3 = alpha; a3.skipBits(v3 * 8);
        var a4 = alpha; a4.skipBits(v4 * 8);
        var a5 = alpha; a5.skipBits(v5 * 8);
        var a6 = alpha; a6.skipBits(v6 * 8);
        var a7 = alpha; a7.skipBits(v7 * 8);
        val expected =
              (a0.preloadUint(8) << 56)
            | (a1.preloadUint(8) << 48)
            | (a2.preloadUint(8) << 40)
            | (a3.preloadUint(8) << 32)
            | (a4.preloadUint(8) << 24)
            | (a5.preloadUint(8) << 16)
            | (a6.preloadUint(8) <<  8)
            |  a7.preloadUint(8);
        if (input.loadUint(64) != expected) { return false; }
        shift -= 48;
    }
    val last16 = hash & 0xFFFF;
    val v0 = (last16 >> 10) & 0x3F;
    val v1 = (last16 >>  4) & 0x3F;
    val v2 = (last16 & 0xF) << 2;
    var a0 = alpha; a0.skipBits(v0 * 8);
    var a1 = alpha; a1.skipBits(v1 * 8);
    var a2 = alpha; a2.skipBits(v2 * 8);
    val expected =
          (a0.preloadUint(8) << 16)
        | (a1.preloadUint(8) <<  8)
        |  a2.preloadUint(8);
    return input.loadUint(24) == expected;
}

// ─── V5: drain via right-shift, no MUL on `acc` ──────────────────────────
// We extract from the bottom instead of the top: take the lowest 6 bits of
// the working copy each step, then `>>= 6`. This dodges the V5-as-left-shift
// overflow and keeps `acc` strictly decreasing.
//
// Order matters: bottom-up gives chars in REVERSE order, so we walk the
// challenge slice from the end. Acton's `slice.skipBits` lets us position
// at the last byte cheaply.
fun verifyB64uChallenge_v5(hash: uint256, challenge: slice): bool {
    // Compare the 43rd char first (handles the 4-bit tail).
    var s: slice = challenge;
    s.skipBits(42 * 8);
    var acc: int = hash;
    val last = (acc & 0xF) << 2;
    if (b64urlCharArith(last) != s.preloadUint(8)) {
        return false;
    }
    acc = acc >> 4;

    // Now compare the remaining 42 chars right-to-left. We already have
    // `s` positioned at byte 42; we need to read backwards, but slices only
    // go forward. Easiest: do a fresh forward pass but pre-shift `acc` so
    // bottom 6 bits already correspond to char index 41 (we shifted off the
    // 4 tail bits, so `acc` has 252 bits = 42 6-bit groups, top group = char 0).
    //
    // To match the forward order of `s`, we instead iterate from the top:
    // take (acc >> (6*(41-i))) & 63, i = 0..41.
    var s2: slice = challenge;
    var i: int = 41;
    repeat (42) {
        val v = (acc >> (i * 6)) & 0x3F;
        if (b64urlCharArith(v) != s2.loadUint(8)) {
            return false;
        }
        i -= 1;
    }
    return true;
}

// ─── V11: 16-byte (128-bit) truncated hash → 22 b64u chars ───────────────
// 32-byte cell hash gives 256-bit security but produces 43 b64u chars.
// 16 bytes still gives 128-bit pre-image resistance (more than secp256k1
// scalars are usually trusted with) and only needs 22 chars to encode,
// roughly halving the b64u work.
//
// 16 bytes = 2 full 48-bit chunks (= 16 chars) + 32 trailing bits (= 6 chars).
fun verifyB64uChallenge_v11(hash128: int, challenge: slice): bool {
    val alpha: slice = B64URL_ALPHABET;
    var input: slice = challenge;
    // Two full 48-bit chunks (top 96 bits of the 128-bit hash).
    var shift: int = 80;   // 128 - 48
    repeat (2) {
        val chunk = (hash128 >> shift) & 0xFFFFFFFFFFFF;
        val v0 = (chunk >> 42) & 0x3F;
        val v1 = (chunk >> 36) & 0x3F;
        val v2 = (chunk >> 30) & 0x3F;
        val v3 = (chunk >> 24) & 0x3F;
        val v4 = (chunk >> 18) & 0x3F;
        val v5 = (chunk >> 12) & 0x3F;
        val v6 = (chunk >>  6) & 0x3F;
        val v7 =  chunk        & 0x3F;
        var a0 = alpha; a0.skipBits(v0 * 8);
        var a1 = alpha; a1.skipBits(v1 * 8);
        var a2 = alpha; a2.skipBits(v2 * 8);
        var a3 = alpha; a3.skipBits(v3 * 8);
        var a4 = alpha; a4.skipBits(v4 * 8);
        var a5 = alpha; a5.skipBits(v5 * 8);
        var a6 = alpha; a6.skipBits(v6 * 8);
        var a7 = alpha; a7.skipBits(v7 * 8);
        val expected =
              (a0.preloadUint(8) << 56)
            | (a1.preloadUint(8) << 48)
            | (a2.preloadUint(8) << 40)
            | (a3.preloadUint(8) << 32)
            | (a4.preloadUint(8) << 24)
            | (a5.preloadUint(8) << 16)
            | (a6.preloadUint(8) <<  8)
            |  a7.preloadUint(8);
        if (input.loadUint(64) != expected) { return false; }
        shift -= 48;
    }
    // Trailing 32 bits → 6 chars (last char encodes only 2 useful bits).
    val last32 = hash128 & 0xFFFFFFFF;
    val v0 = (last32 >> 26) & 0x3F;
    val v1 = (last32 >> 20) & 0x3F;
    val v2 = (last32 >> 14) & 0x3F;
    val v3 = (last32 >>  8) & 0x3F;
    val v4 = (last32 >>  2) & 0x3F;
    val v5 = (last32 & 0x3) << 4;
    var a0 = alpha; a0.skipBits(v0 * 8);
    var a1 = alpha; a1.skipBits(v1 * 8);
    var a2 = alpha; a2.skipBits(v2 * 8);
    var a3 = alpha; a3.skipBits(v3 * 8);
    var a4 = alpha; a4.skipBits(v4 * 8);
    var a5 = alpha; a5.skipBits(v5 * 8);
    val expected =
          (a0.preloadUint(8) << 40)
        | (a1.preloadUint(8) << 32)
        | (a2.preloadUint(8) << 24)
        | (a3.preloadUint(8) << 16)
        | (a4.preloadUint(8) <<  8)
        |  a5.preloadUint(8);
    return input.loadUint(48) == expected;
}

// ─── V12: 12-byte (96-bit) hash → 16 b64u chars ──────────────────────────
// 12 bytes splits cleanly into 2 full 48-bit chunks (no trailing bits).
fun verifyB64uChallenge_v12(hash96: int, challenge: slice): bool {
    val alpha: slice = B64URL_ALPHABET;
    var input: slice = challenge;
    var shift: int = 48;   // 96 - 48
    repeat (2) {
        val chunk = (hash96 >> shift) & 0xFFFFFFFFFFFF;
        val v0 = (chunk >> 42) & 0x3F;
        val v1 = (chunk >> 36) & 0x3F;
        val v2 = (chunk >> 30) & 0x3F;
        val v3 = (chunk >> 24) & 0x3F;
        val v4 = (chunk >> 18) & 0x3F;
        val v5 = (chunk >> 12) & 0x3F;
        val v6 = (chunk >>  6) & 0x3F;
        val v7 =  chunk        & 0x3F;
        var a0 = alpha; a0.skipBits(v0 * 8);
        var a1 = alpha; a1.skipBits(v1 * 8);
        var a2 = alpha; a2.skipBits(v2 * 8);
        var a3 = alpha; a3.skipBits(v3 * 8);
        var a4 = alpha; a4.skipBits(v4 * 8);
        var a5 = alpha; a5.skipBits(v5 * 8);
        var a6 = alpha; a6.skipBits(v6 * 8);
        var a7 = alpha; a7.skipBits(v7 * 8);
        val expected =
              (a0.preloadUint(8) << 56)
            | (a1.preloadUint(8) << 48)
            | (a2.preloadUint(8) << 40)
            | (a3.preloadUint(8) << 32)
            | (a4.preloadUint(8) << 24)
            | (a5.preloadUint(8) << 16)
            | (a6.preloadUint(8) <<  8)
            |  a7.preloadUint(8);
        if (input.loadUint(64) != expected) { return false; }
        shift -= 48;
    }
    return true;
}

// ─── V13: V12 with the 2-iteration loop manually unrolled ─────────────
// REPEAT + 2 iters has tiny but non-zero overhead. With only 2 chunks the
// unroll is short enough to read.
fun verifyB64uChallenge_v13(hash96: int, challenge: slice): bool {
    val alpha: slice = B64URL_ALPHABET;
    var input: slice = challenge;
    // Chunk 0: top 48 bits of hash96.
    val chunk0 = (hash96 >> 48) & 0xFFFFFFFFFFFF;
    var a0 = alpha; a0.skipBits(((chunk0 >> 42) & 0x3F) * 8);
    var a1 = alpha; a1.skipBits(((chunk0 >> 36) & 0x3F) * 8);
    var a2 = alpha; a2.skipBits(((chunk0 >> 30) & 0x3F) * 8);
    var a3 = alpha; a3.skipBits(((chunk0 >> 24) & 0x3F) * 8);
    var a4 = alpha; a4.skipBits(((chunk0 >> 18) & 0x3F) * 8);
    var a5 = alpha; a5.skipBits(((chunk0 >> 12) & 0x3F) * 8);
    var a6 = alpha; a6.skipBits(((chunk0 >>  6) & 0x3F) * 8);
    var a7 = alpha; a7.skipBits(((chunk0       ) & 0x3F) * 8);
    val expected0 =
              (a0.preloadUint(8) << 56)
            | (a1.preloadUint(8) << 48)
            | (a2.preloadUint(8) << 40)
            | (a3.preloadUint(8) << 32)
            | (a4.preloadUint(8) << 24)
            | (a5.preloadUint(8) << 16)
            | (a6.preloadUint(8) <<  8)
            |  a7.preloadUint(8);
    if (input.loadUint(64) != expected0) { return false; }
    // Chunk 1: bottom 48 bits.
    val chunk1 = hash96 & 0xFFFFFFFFFFFF;
    var b0 = alpha; b0.skipBits(((chunk1 >> 42) & 0x3F) * 8);
    var b1 = alpha; b1.skipBits(((chunk1 >> 36) & 0x3F) * 8);
    var b2 = alpha; b2.skipBits(((chunk1 >> 30) & 0x3F) * 8);
    var b3 = alpha; b3.skipBits(((chunk1 >> 24) & 0x3F) * 8);
    var b4 = alpha; b4.skipBits(((chunk1 >> 18) & 0x3F) * 8);
    var b5 = alpha; b5.skipBits(((chunk1 >> 12) & 0x3F) * 8);
    var b6 = alpha; b6.skipBits(((chunk1 >>  6) & 0x3F) * 8);
    var b7 = alpha; b7.skipBits(((chunk1       ) & 0x3F) * 8);
    val expected1 =
              (b0.preloadUint(8) << 56)
            | (b1.preloadUint(8) << 48)
            | (b2.preloadUint(8) << 40)
            | (b3.preloadUint(8) << 32)
            | (b4.preloadUint(8) << 24)
            | (b5.preloadUint(8) << 16)
            | (b6.preloadUint(8) <<  8)
            |  b7.preloadUint(8);
    return input.loadUint(64) == expected1;
}

// ─── End-to-end pre-ACCEPT cost: HASHEXT + b64u-binding + P256 ───────────
// check-disable-next-line asm-function-missing-safety-comment
fun p256ChkSignS(d: slice, sig: slice, pubKey: slice): bool asm "P256_CHKSIGNS";
// check-disable-next-line asm-function-missing-safety-comment
fun sha256ThreeSlices(s1: slice, s2: slice, s3: slice): uint256 asm "3 PUSHINT HASHEXT_SHA256";

// Test vector for the two-phase end-to-end (32-byte challenge, 43 b64u chars).
// Produced by scripts/gen-test-vector.mjs with a 32-byte challengeBytes.
const PUBKEY_COMPRESSED  = "02e66e327f3a54b0aaf0a7769f887a221bcd06172a6d3dd2b0825629b46464f00e";
const SIGNATURE_RAW      = "c953b0d9b8405620fb9e3649cfd16e2146d198f12aedfd0bab9379345058c317ec2d03b8b006dc9cbf7c79e33c1510eff4ae7d392c11276adc581b5895d6426d";
const AUTH_DATA          = "49960de5880e8c687434170f6476605b8fe4aeb9a28632c7995cf3ba831d97630500000001";
const CDJ_PREFIX         = "7b2274797065223a22776562617574686e2e676574222c226368616c6c656e6765223a22";
const CDJ_SUFFIX         = "222c226f726967696e223a22687474703a2f2f6c6f63616c686f73743a3532323631222c2263726f73734f726967696e223a66616c73657d";
const CDJ_CHALLENGE_43   = "536b744d545535505546465355315256566c645957564252556c4e5556565a5857466c6157317864586c38";
// First 12 bytes of the body hash (96-bit prefix), used by the cheap pre-ACCEPT check.
const FAKE_BODY_HASH_96  = 0x4a4b4c4d4e4f505152535455;
// Full 32-byte body hash, used by the full post-ACCEPT check.
const FAKE_BODY_HASH_256 = 0x4a4b4c4d4e4f50515253545556575859505152535455565758595a5b5c5d5e5f;

// ─── Test vector (matches b64url.test.tolk) ──────────────────────────────

const HASH32_HEX        = "4a4b4c4d4e4f50515253545556575859505152535455565758595a5b5c5d5e5f";
const EXPECTED_B64U_HEX = "536b744d545535505546465355315256566c645957564252556c4e5556565a5857466c6157317864586c38";

fun loadHash32(): uint256 {
    var s: slice = HASH32_HEX.hexToSlice();
    return s.loadUint(256);
}

// ─── Correctness ──────────────────────────────────────────────────────────

get fun `test fast: char map matches alphabet for all 64 values`() {
    val ALPHABET: slice = "4142434445464748494a4b4c4d4e4f505152535455565758595a6162636465666768696a6b6c6d6e6f707172737475767778797a303132333435363738392d5f".hexToSlice();
    var v: int = 0;
    repeat (64) {
        var s = ALPHABET;
        s.skipBits(v * 8);
        val expected = s.preloadUint(8);
        expect(b64urlCharArith(v)).toEqual(expected);
        v += 1;
    }
}

get fun `test fast: V2 (encode + SDEQ) matches expected challenge`() {
    val ok = verifyB64uChallenge_v2(loadHash32(), EXPECTED_B64U_HEX.hexToSlice());
    expect(ok).toBeTrue();
}

get fun `test fast: V3 (compare-as-you-go) matches expected challenge`() {
    val ok = verifyB64uChallenge_v3(loadHash32(), EXPECTED_B64U_HEX.hexToSlice());
