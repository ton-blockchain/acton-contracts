fun NotcoinMinter.getTotalSupply(self): int {
    return self.getJettonData().totalSupply;
}

fun NotcoinMinter.getAdminAddress(self): address? {
    return self.getJettonData().adminAddress;
}

fun NotcoinMinter.getContent(self): cell {
    return self.getJettonData().jettonContent;
}

fun NotcoinWallet.getJettonBalance(self): coins {
    if (!scripts.isContractDeployed(self.address)) {
        return 0;
    }

    val result: JettonWalletDataReply = net.runGetMethod(self.address, "get_wallet_data");
    return result.jettonBalance;
}

fun NotcoinWallet.sendTransfer(
    self,
    from: address,
    value: int,
    jettonAmount: int,
    recipient: address,
    responseAddress: address,
    customPayload: cell?,
    forwardTonAmount: int,
    forwardPayload: cell?,
): SendResultList {
    val outMessage = createMessage({
        bounce: true,
        value,
        dest: self.address,
        body: AskToTransfer {
            queryId: 0,
            jettonAmount,
            transferRecipient: recipient,
            sendExcessesTo: responseAddress,
            customPayload,
            forwardTonAmount,
            forwardPayload: beginCell()
                .storeMaybeRef(forwardPayload.toCell())
                .endCell()
                .beginParse(),
        },
    });
    return net.send(from, outMessage);
}

fun NotcoinWallet.sendBurn(
    self,
    from: address,
    value: int,
    jettonAmount: int,
    responseAddress: address,
    customPayload: cell?,
): SendResultList {
    val outMessage = createMessage({
        bounce: false,
        value,
        dest: self.address,
        body: AskToBurn {
            queryId: 0,
            jettonAmount,
            sendExcessesTo: responseAddress,
            customPayload,
        },
    });
    return net.send(from, outMessage);
}
